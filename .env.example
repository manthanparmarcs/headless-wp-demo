# Copy to .env.local in THIS folder (next to package.json), then restart `npm run dev`.
#
# GraphQL endpoint (same URL you use in the browser for WPGraphQL)
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://wordpress-401163-6209935.cloudwaysapps.com/graphql

# --- Mutations (create / update / delete): use ONE method. Do not use NEXT_PUBLIC_* for secrets. ---

# Method A: WordPress Application Password
# WP Admin → Users → Your Profile → Application Passwords → create one, paste here (spaces OK).
WORDPRESS_GRAPHQL_USERNAME=
WORDPRESS_GRAPHQL_APPLICATION_PASSWORD=

# Method B: JWT (e.g. WPGraphQL JWT Authentication) — uncomment and set token instead of A.
# WORDPRESS_GRAPHQL_AUTH_TOKEN=

# --- Contact Form 7 (CF7) forwarding for /api/cf7/submit ---
# Prefer setting CF7_FEEDBACK_URL directly.
# If you don't want to hardcode the full URL, you can set the components below.
#
# Feedback endpoint shape (typical):
#   /wp-json/<namespace>/v1/contact-forms/<ID>/feedback
CF7_FEEDBACK_URL=

# Optional components for constructing CF7_FEEDBACK_URL
CF7_REST_BASE_URL=https://wordpress-401163-6209935.cloudwaysapps.com/wp-json
CF7_REST_NAMESPACE=contact-form-7
CF7_FORM_ID=203c2c4

# Optional: must match the CF7 form's unit tag (_wpcf7_unit_tag) if your CF7 setup requires it.
CF7_UNIT_TAG=nextjs-form
